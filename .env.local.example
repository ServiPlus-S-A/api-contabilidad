# =============================================================================
# LOCAL development environment — copy to .env.local and edit values.
# This file is for running the project on your own machine.
# The DB name (contabilidad_local) is intentionally different from production
# so local data never touches the production database.
# NEVER commit .env.local to version control.
# =============================================================================

# --- Database (MariaDB) -------------------------------------------------------
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=contabilidad_local
DB_USER=contabilidad_user
DB_PASSWORD=local_dev_password
DB_ROOT_PASSWORD=local_root_password
DB_POOL_SIZE=5

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=local_redis_password

# --- MinIO (Object Storage for PDF files) ------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=local_minio_key
MINIO_SECRET_KEY=local_minio_secret
MINIO_BUCKET=contabilidad-pdfs-local
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=local_dev_jwt_secret_minimum_32_characters_long
JWT_EXPIRATION=86400000

# --- Backend (Spring Boot) ---------------------------------------------------
SERVER_PORT=8080
LOG_LEVEL=DEBUG
JPA_SHOW_SQL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# --- Email (SMTP) ------------------------------------------------------------
# Use Mailpit locally: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
EMAIL_FROM=dev@contabilidad.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# --- Frontend (Vite / React) -------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Kong Gateway ------------------------------------------------------------
KONG_ADMIN_PORT=8001
KONG_PROXY_PORT=8000
