# =============================================================================
# api-contabilidad — PRODUCTION environment variables
# Used by the CD pipeline on the EC2 server.
# Copy to .env on the server and fill in real values.
#
# For LOCAL development use .env.local.example instead:
#   cp .env.local.example .env.local
#   docker compose -f docker-compose.yml -f docker-compose.local.yml \
#     --env-file .env.local up --build
#
# NEVER commit .env or .env.local to version control.
# =============================================================================

# --- Database (MariaDB) -------------------------------------------------------
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=contabilidad
DB_USER=contabilidad_user
DB_PASSWORD=your_strong_db_password_here
DB_ROOT_PASSWORD=your_strong_root_password_here
DB_POOL_SIZE=10

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here

# --- MinIO (Object Storage for PDF files) ------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key_here
MINIO_SECRET_KEY=your_minio_secret_key_here
MINIO_BUCKET=contabilidad-pdfs
# Public endpoint for presigned URL generation (may differ from internal endpoint)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- JWT (must match Kong Gateway jwt plugin secret) -------------------------
JWT_SECRET=your_256_bit_minimum_jwt_secret_here_replace_with_strong_random_value
JWT_EXPIRATION=86400000

# --- Backend (Spring Boot) ---------------------------------------------------
SERVER_PORT=8080
LOG_LEVEL=INFO
JPA_SHOW_SQL=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Email (SMTP for EmailCotizacionTask) ------------------------------------
EMAIL_FROM=noreply@yummy.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here

# --- Frontend (Vite / React) --------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Kong Gateway ------------------------------------------------------------
KONG_ADMIN_PORT=8001
KONG_PROXY_PORT=8000
# Public hostname or IP of this deployment (used for Kong CORS origins)
PUBLIC_HOST=<YOUR_EC2_IP>
