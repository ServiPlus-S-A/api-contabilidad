# Normalize line endings to LF on commit; let git convert on checkout per OS
* text=auto
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binaries — never diff, never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
