# =============================================================================
# DEVELOPMENT / STAGING environment variables
# Used by cd-develop.yml when deploying to EC2.
# Copy to .env.dev on the server and fill in values.
# DB name (contabilidad_dev) is intentionally different from production.
# NEVER commit .env.dev to version control.
# =============================================================================

# --- Database (MariaDB) -------------------------------------------------------
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=contabilidad_dev
DB_USER=contabilidad_user
DB_PASSWORD=your_dev_db_password_here
DB_ROOT_PASSWORD=your_dev_root_password_here
DB_POOL_SIZE=5

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_dev_redis_password_here

# --- MinIO -------------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_dev_minio_key_here
MINIO_SECRET_KEY=your_dev_minio_secret_here
MINIO_BUCKET=contabilidad-pdfs-dev
MINIO_PUBLIC_ENDPOINT=http://<YOUR_EC2_IP>:9000

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=your_dev_jwt_secret_minimum_32_characters_long
JWT_EXPIRATION=86400000

# --- Backend -----------------------------------------------------------------
SERVER_PORT=8080
LOG_LEVEL=DEBUG
JPA_SHOW_SQL=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://<YOUR_EC2_IP>:8100

# --- Email -------------------------------------------------------------------
EMAIL_FROM=dev@serviplus.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here

# --- Frontend ----------------------------------------------------------------
VITE_API_BASE_URL=http://<YOUR_EC2_IP>:8100/api/v1

# --- Kong Gateway ------------------------------------------------------------
KONG_ADMIN_PORT=8101
KONG_PROXY_PORT=8100
# Public hostname or IP of this deployment (used for Kong CORS origins in kong.dev.yml)
PUBLIC_HOST=<YOUR_EC2_IP>

# --- Docker Hub (needed by docker-compose.dev.yml image references) ----------
DOCKERHUB_USERNAME=your_dockerhub_username_here
